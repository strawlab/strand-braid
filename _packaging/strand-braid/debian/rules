#!/usr/bin/make -f

# This is a hack. We cannot build from clean source. Download binary and
# then run the debian stuff.

%:
	dh $@

override_dh_shlibdeps:
	# The -Xpylon-cabi tells dh_shlibdeps to not analyze `libpylon-cabi.so` by
	# excluding it from the dependency calculation.
	dh_shlibdeps -a -Xpylon-cabi --dpkg-shlibdeps-params=--ignore-missing-info
